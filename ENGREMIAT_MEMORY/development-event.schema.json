{
    "schema_id":  "development-event.schema.v1",
    "required":  [
                     "event_id",
                     "objective_id",
                     "stage_id",
                     "status",
                     "source_path",
                     "evidence_sha256",
                     "created_at"
                 ],
    "statuses":  [
                     "OK",
                     "ERR",
                     "NO_GO",
                     "READY",
                     "CLOSE",
                     "UNKNOWN"
                 ],
    "fields":  {
                   "event_id":  "unique stable id",
                   "objective_id":  "objective from evidence or inferred",
                   "stage_id":  "stage from evidence or inferred",
                   "block_id":  "optional block",
                   "step_id":  "optional step",
                   "status":  "OK ERR NO_GO READY CLOSE UNKNOWN",
                   "source_path":  "local evidence path",
                   "evidence_sha256":  "source hash",
                   "artifact":  "optional artifact path",
                   "risk":  "LOW MEDIUM HIGH",
                   "next":  "next step/action",
                   "created_at":  "iso datetime"
               }
}
