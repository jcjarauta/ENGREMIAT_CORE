{
    "schema":  "prompt-envelope",
    "purpose":  "Evitar prompts sueltos y asegurar trazabilidad",
    "required":  [
                     "envelope_id",
                     "system_role",
                     "user_goal",
                     "context_refs",
                     "constraints",
