                       "active_stage":  "active stage id",
                       "active_block":  "active block id",
                       "active_step":  "active step id",
                       "last_validated":  "last validated step id",
                       "artifacts":  "recent artifact references",
                       "gates":  "pending gate summary",
                       "errors":  "last/open error summary",
                       "readiness":  "current readiness summary",
                       "next":  "recommended next action",
