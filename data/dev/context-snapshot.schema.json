    "required":  [
                     "objective_id",
                     "active_stage",
                     "active_block",
                     "active_step",
                     "last_validated",
                     "artifacts",
                     "gates",
                     "errors",
                     "readiness",
                     "next",
                     "norms",
                     "updated_at"
                 ],
