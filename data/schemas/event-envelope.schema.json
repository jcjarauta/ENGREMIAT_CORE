                     "event_type",
                     "entity_id",
                     "issuer",
                     "timestamp",
                     "trace_id",
                     "correlation_id",
                     "payload",
                     "payload_hash",
                     "previous_event_hash"
                 ],
    "additionalProperties":  true,
    "properties":  {
                       "event_id":  {
                                        "type":  "string"
                                    },
                       "event_type":  {
                                          "type":  "string"
                                      },
                       "entity_id":  {
                                         "type":  "string"
                                     },
                       "issuer":  {
                                      "type":  "string"
                                  },
                       "timestamp":  {
                                         "type":  "string"
                                     },
                       "trace_id":  {
                                        "type":  "string"
                                    },
                       "correlation_id":  {
                                              "type":  "string"
                                          },
                       "payload":  {
                                       "type":  "object"
                                   },
                       "payload_hash":  {
                                            "type":  "string"
                                        },
                       "previous_event_hash":  {
                                                   "type":  "string"
                                               }
                   }
}
