                                           "type":  "string"
                                       },
                       "gate_id":  {
                                       "type":  "string"
                                   },
                       "card_id":  {
                                       "type":  "string"
                                   },
                       "blueprint_id":  {
                                            "type":  "string"
                                        },
                       "scope":  {
                                     "const":  "GATE_JSON_MUTATION_ONLY_NO_EXECUTION",
                                     "type":  "string"
                                 },
                       "allowed_mutations":  {
                                                 "items":  {
                                                               "type":  "object"
                                                           },
                                                 "type":  "array"
                                             },
                       "forbidden_actions":  {
                                                 "items":  {
                                                               "type":  "string"
                                                           },
                                                 "type":  "array"
                                             },
                       "safety_rules":  {
                                            "items":  {
                                                          "type":  "string"
                                                      },
                                            "type":  "array"
                                        },
                       "status":  {
                                      "type":  "string"
                                  }
                   }
}