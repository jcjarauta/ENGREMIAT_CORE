    "purpose":  "Definir emisor minimo de heartbeat local para publicar estado vivo consumible por Projects Center",
    "runtime_dependency_policy":  "LOCAL_FILES_ONLY",
    "obsidian_policy":  "Markdown YAML export only; Obsidian is visualization, not runtime dependency",
    "writer_outputs":  [
                           "documents/worker-sync/worker-heartbeat-latest.json",
                           "documents/worker-sync/worker-events.jsonl",
                           "documents/worker-sync/project-signal-latest.json"
                       ],
    "required_fields":  [
                            "schema_version",
                            "signal_id",
                            "project_id",
                            "project_path",
                            "worker_id",
                            "task_id",
                            "state",
                            "phase",
                            "current_step",
                            "progress_pct",
                            "blocked_reason",
                            "next_action",
                            "evidence_path",
                            "heartbeat_at",
                            "expires_at",
                            "source",
                            "readonly"
                        ],
    "allowed_states":  [
                           "IDLE",
                           "QUEUED",
                           "RUNNING",
                           "WAITING_HUMAN",
                           "BLOCKED",
                           "DONE",
                           "ERROR"
                       ],
    "rules":  [
                  "heartbeat_at local timestamp",
                  "expires_at controls signal freshness",
                  "RUNNING without blocked_reason displays OK",
                  "blocked_reason forces BLOCK",
                  "project_signal summarizes heartbeat for terminal views",
                  "writer publishes state only and does not execute tasks"
              ],
