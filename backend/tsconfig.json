{
    "include":  [
                    "src/**/*.ts"
                ],
    "compilerOptions":  {
                            "module":  "commonjs",
                            "declaration":  true,
                            "removeComments":  true,
                            "emitDecoratorMetadata":  true,
                            "experimentalDecorators":  true,
                            "allowSyntheticDefaultImports":  true,
                            "target":  "ES2021",
                            "sourceMap":  true,
                            "rootDir":  "./src",
                            "outDir":  "./dist",
                            "incremental":  true,
                            "strict":  false,
                            "skipLibCheck":  true,
                            "ignoreDeprecations":  "6.0",
                            "types":  [
                                          "node"
                                      ]
                        }
}