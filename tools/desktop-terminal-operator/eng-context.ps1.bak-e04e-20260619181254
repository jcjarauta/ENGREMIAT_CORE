$ErrorActionPreference="Stop"
[Console]::OutputEncoding=[System.Text.UTF8Encoding]::new()
$ScriptDir=Split-Path -Parent $MyInvocation.MyCommand.Path
$Root=(Resolve-Path (Join-Path $ScriptDir "..\..")).Path
$StateDir=Join-Path $Root "data\operator-state"
$StateFile=Join-Path $StateDir "active-context.json"
function L($m,$c="Gray"){Write-Host $m -ForegroundColor $c}
function D($p){if(!(Test-Path -LiteralPath $p)){New-Item -ItemType Directory -Force -Path $p|Out-Null}}
function J($p,$o){$d=Split-Path $p -Parent;D $d;$o|ConvertTo-Json -Depth 100|Set-Content -LiteralPath $p -Encoding UTF8}
function LoadState(){D $StateDir;if(!(Test-Path -LiteralPath $StateFile)){J $StateFile ([ordered]@{mode="global";active_project="";active_master_vault="";active_module="";active_module_vault="";last_command="init";last_report="";next="abrir-proyecto_or_nuevo-proyecto";updated_at=(Get-Date).ToString("s");safety=[ordered]@{local_only=$true;worker_real=$false;git=$false;network=$false}})};return (Get-Content -LiteralPath $StateFile -Raw -Encoding UTF8|ConvertFrom-Json)}
function SaveState($s){$s.updated_at=(Get-Date).ToString("s");J $StateFile $s}
function Projects(){ $desktop=[Environment]::GetFolderPath("Desktop"); return @(Get-ChildItem -LiteralPath $desktop -Directory -Filter "ENGREMIAT_PROJECT_*" -ErrorAction SilentlyContinue|Where-Object{Test-Path -LiteralPath (Join-Path $_.FullName "BOVEDA_MAESTRA")}|Sort-Object LastWriteTime -Descending)}
$cmd=if($args.Count -gt 0){([string]$args[0]).Trim().ToLowerInvariant()}else{"show"}
if($cmd -eq "show"){
  $s=LoadState
  L "CONTEXTO ENGREMIAT" Cyan
  L ("mode="+$s.mode) Green
  L ("active_project="+$s.active_project) Green
  L ("active_module="+$s.active_module) Green
  L ("next="+$s.next) Yellow
  exit
}
elseif($cmd -eq "projects"){
  $ps=Projects
  if(@($ps).Count -eq 0){L "WARN no_projects_found" Yellow;exit}
  L "PROYECTOS DISPONIBLES" Cyan
  for($i=0;$i -lt @($ps).Count;$i++){L (" ["+($i+1)+"] "+$ps[$i].Name+"  "+$ps[$i].LastWriteTime.ToString("yyyy-MM-dd HH:mm")) Green}
  exit
}
elseif($cmd -eq "open-project"){
  $ps=Projects
  if(@($ps).Count -eq 0){throw "no_projects_found"}
  L "SELECCIONA PROYECTO ACTIVO" Cyan
  for($i=0;$i -lt @($ps).Count;$i++){L (" ["+($i+1)+"] "+$ps[$i].Name+"  "+$ps[$i].LastWriteTime.ToString("yyyy-MM-dd HH:mm")) Green}
  $sel=Read-Host "Numero de proyecto"
  [int]$n=0
  if(![int]::TryParse($sel,[ref]$n)){throw "invalid_project_selection"}
  if($n -lt 1 -or $n -gt @($ps).Count){throw "project_selection_out_of_range"}
  $p=$ps[$n-1].FullName
  $s=LoadState
  $s.mode="project"
  $s.active_project=$p
  $s.active_master_vault=Join-Path $p "BOVEDA_MAESTRA"
  $s.active_module=""
  $s.active_module_vault=""
  $s.last_command="abrir-proyecto","abrir-proyectos"
  $s.next="revisar-proyecto_or_modulos_or_nuevo-modulo"
  SaveState $s
  L ("OK active_project="+$p+" next="+$s.next) Green
  exit
}
elseif($cmd -eq "modules"){
  $s=LoadState
  if([string]::IsNullOrWhiteSpace($s.active_project)){throw "no_active_project"}
  $root=Join-Path $s.active_project "MODULOS"
  if(!(Test-Path -LiteralPath $root)){L "WARN no_modules_root" Yellow;exit}
  $ms=@(Get-ChildItem -LiteralPath $root -Directory -Filter "MODULE_*" -ErrorAction SilentlyContinue|Where-Object{Test-Path -LiteralPath (Join-Path $_.FullName "BOVEDA_MODULO")}|Sort-Object Name)
  if(@($ms).Count -eq 0){L "WARN no_modules_found" Yellow;exit}
  L "MODULOS DEL PROYECTO ACTIVO" Cyan
  for($i=0;$i -lt @($ms).Count;$i++){L (" ["+($i+1)+"] "+$ms[$i].Name) Green}
  exit
}
elseif($cmd -eq "open-module"){
  $s=LoadState
  if([string]::IsNullOrWhiteSpace($s.active_project)){throw "no_active_project"}
  $root=Join-Path $s.active_project "MODULOS"
  $ms=@(Get-ChildItem -LiteralPath $root -Directory -Filter "MODULE_*" -ErrorAction SilentlyContinue|Where-Object{Test-Path -LiteralPath (Join-Path $_.FullName "BOVEDA_MODULO")}|Sort-Object Name)
  if(@($ms).Count -eq 0){throw "no_modules_found"}
  L "SELECCIONA MODULO ACTIVO" Cyan
  for($i=0;$i -lt @($ms).Count;$i++){L (" ["+($i+1)+"] "+$ms[$i].Name) Green}
  $sel=Read-Host "Numero de modulo"
  [int]$n=0
  if(![int]::TryParse($sel,[ref]$n)){throw "invalid_module_selection"}
  if($n -lt 1 -or $n -gt @($ms).Count){throw "module_selection_out_of_range"}
  $m=$ms[$n-1]
  $s.mode="module"
  $s.active_module=$m.Name
  $s.active_module_vault=Join-Path $m.FullName "BOVEDA_MODULO"
  $s.last_command="abrir-modulo"
  $s.next="revisar-modulo_or_contrato_or_tareas"
  SaveState $s
  L ("OK active_module="+$m.Name+" module_vault="+$s.active_module_vault+" next="+$s.next) Green
  exit
}
else{throw "unknown_context_command $cmd"}


