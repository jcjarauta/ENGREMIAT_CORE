$ErrorActionPreference="Stop"
[Console]::OutputEncoding=[System.Text.UTF8Encoding]::new()
$Root=(Resolve-Path (Join-Path $PSScriptRoot "..\..")).Path
Set-Location -LiteralPath $Root
$StateDir=Join-Path $Root "data\operator-state"
$StateFile=Join-Path $StateDir "active-context.json"
function L($m,$c="Gray"){Write-Host $m -ForegroundColor $c}
function D($p){if(!(Test-Path -LiteralPath $p)){New-Item -ItemType Directory -Force -Path $p|Out-Null}}
function J($p,$o){$d=Split-Path $p -Parent;D $d;$o|ConvertTo-Json -Depth 100|Set-Content -LiteralPath $p -Encoding UTF8}
function LoadState(){D $StateDir;if(!(Test-Path -LiteralPath $StateFile)){J $StateFile ([ordered]@{mode="global";active_project="";active_master_vault="";active_module="";active_module_vault="";historical_projects=@();last_command="init";next="abrir-proyecto_or_nuevo-proyecto";updated_at=(Get-Date).ToString("s");safety=[ordered]@{local_only=$true;worker_real=$false;git=$false;network=$false}})};return (Get-Content -LiteralPath $StateFile -Raw -Encoding UTF8|ConvertFrom-Json)}
function SaveState($s){$s|Add-Member -Force -NotePropertyName updated_at -NotePropertyValue (Get-Date).ToString("s");J $StateFile $s}
function Projects(){$desktop=[Environment]::GetFolderPath("Desktop");return @(Get-ChildItem -LiteralPath $desktop -Directory -Filter "ENGREMIAT_PROJECT_*" -ErrorAction SilentlyContinue|Where-Object{Test-Path -LiteralPath (Join-Path $_.FullName "BOVEDA_MAESTRA")}|Sort-Object LastWriteTime -Descending)}
function Modules($project){$mroot=Join-Path $project "MODULOS";if(!(Test-Path -LiteralPath $mroot)){return @()};return @(Get-ChildItem -LiteralPath $mroot -Directory -Filter "MODULE_*" -ErrorAction SilentlyContinue|Where-Object{Test-Path -LiteralPath (Join-Path $_.FullName "BOVEDA_MODULO")}|Sort-Object Name)}
function EnsureHistoryForTest($s,$all){if(!($s.PSObject.Properties.Name -contains "historical_projects")){$s|Add-Member -Force -NotePropertyName historical_projects -NotePropertyValue @()};if(@($s.historical_projects).Count -eq 0 -and @($all).Count -ge 3){$hist=@($all[0],$all[1]);$s|Add-Member -Force -NotePropertyName historical_projects -NotePropertyValue @($hist|ForEach-Object{[pscustomobject]@{name=$_.Name;path=$_.FullName;status="HISTORICAL"}});SaveState $s};return (LoadState)}
function HistoricalPaths($s){if($s.PSObject.Properties.Name -contains "historical_projects" -and $s.historical_projects){return @($s.historical_projects|ForEach-Object{if($_.path){[string]$_.path}else{[string]$_}})};return @()}
function SelectModule($s,$arg=""){$ms=Modules $s.active_project;if(@($ms).Count -eq 0){L "WARN no_modules_found; usa nuevo-modulo" Yellow;return $s};L "SELECCIONA MODULO ACTIVO" Cyan;for($i=0;$i -lt @($ms).Count;$i++){L (" ["+($i+1)+"] "+$ms[$i].Name) Green};$sel=$arg;if([string]::IsNullOrWhiteSpace($sel)){$sel=Read-Host "Numero de modulo"};[int]$n=0;if(![int]::TryParse($sel,[ref]$n)){throw "invalid_module_selection"};if($n -lt 1 -or $n -gt @($ms).Count){throw "module_selection_out_of_range"};$m=$ms[$n-1];$s.mode="module";$s.active_module=$m.Name;$s.active_module_vault=Join-Path $m.FullName "BOVEDA_MODULO";$s.last_command="abrir-modulo";$s.next="contrato_or_tareas_or_evidencias";SaveState $s;L ("OK active_module="+$m.Name+" next="+$s.next) Green;return $s}
$cmd=if($args.Count -gt 0){([string]$args[0]).Trim().ToLowerInvariant()}else{"show"}
$cmdArg=if($args.Count -gt 1){([string]$args[1]).Trim()}else{""}
if($cmd -eq "show"){$s=LoadState;L "CONTEXTO ENGREMIAT" Cyan;L ("mode="+$s.mode) Green;L ("active_project="+$s.active_project) Green;L ("active_module="+$s.active_module) Green;L ("next="+$s.next) Yellow;exit}
elseif($cmd -eq "projects"){$all=Projects;if(@($all).Count -eq 0){L "WARN no_projects_found" Yellow;exit};$s=EnsureHistoryForTest (LoadState) $all;$histPaths=HistoricalPaths $s;$active=[string]$s.active_project;L "PROYECTOS HISTORICOS / DISPONIBLES" Cyan;for($i=0;$i -lt @($all).Count;$i++){$tag="";if($all[$i].FullName -eq $active){$tag=" ACTIVE"}elseif($histPaths -contains $all[$i].FullName){$tag=" HISTORICO"};L (" ["+($i+1)+"] "+$all[$i].Name+"  "+$all[$i].LastWriteTime.ToString("yyyy-MM-dd HH:mm")+$tag) Green};exit}
elseif($cmd -eq "open-project"){$all=Projects;if(@($all).Count -eq 0){throw "no_projects_found"};$s=EnsureHistoryForTest (LoadState) $all;$histPaths=HistoricalPaths $s;$ps=@($all|Where-Object{$histPaths -notcontains $_.FullName});if(@($ps).Count -eq 0){$ps=@($all)};L "SELECCIONA PROYECTO ACTIVO" Cyan;for($i=0;$i -lt @($ps).Count;$i++){L (" ["+($i+1)+"] "+$ps[$i].Name+"  "+$ps[$i].LastWriteTime.ToString("yyyy-MM-dd HH:mm")) Green};$sel=$cmdArg;if([string]::IsNullOrWhiteSpace($sel)){$sel=Read-Host "Numero de proyecto"};[int]$n=0;if(![int]::TryParse($sel,[ref]$n)){throw "invalid_project_selection"};if($n -lt 1 -or $n -gt @($ps).Count){throw "project_selection_out_of_range"};$p=$ps[$n-1].FullName;$s=LoadState;$s.mode="project";$s.active_project=$p;$s.active_master_vault=Join-Path $p "BOVEDA_MAESTRA";$s.active_module="";$s.active_module_vault="";$s.last_command="abrir-proyecto";$s.next="seleccionar_modulo";SaveState $s;L ("OK active_project="+$p) Green;L "NEXT selecciona modulo para entrar al trabajo" Magenta;$s=SelectModule $s "";exit}
elseif($cmd -eq "modules"){$s=LoadState;if([string]::IsNullOrWhiteSpace($s.active_project)){throw "no_active_project"};$ms=Modules $s.active_project;if(@($ms).Count -eq 0){L "WARN no_modules_found" Yellow;exit};L "MODULOS DEL PROYECTO ACTIVO" Cyan;for($i=0;$i -lt @($ms).Count;$i++){L (" ["+($i+1)+"] "+$ms[$i].Name) Green};exit}
elseif($cmd -eq "open-module"){$s=LoadState;if([string]::IsNullOrWhiteSpace($s.active_project)){throw "no_active_project"};$s=SelectModule $s $cmdArg;exit}
else{throw "unknown_context_command=$cmd"}
