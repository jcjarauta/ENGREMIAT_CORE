$ErrorActionPreference="Stop"
[Console]::OutputEncoding=[System.Text.UTF8Encoding]::new()

$Core="C:\ENGREMIAT_CORE"
$ToolDir=Join-Path $Core "tools\desktop-terminal-operator"

function W($m,$c="White"){ Write-Host $m -ForegroundColor $c }
function P(){ [void](Read-Host "Enter") }

function ActiveProject(){
  $j=Join-Path $Core "data\desktop-terminal-operator\active-project.json"
  $t=Join-Path $Core "data\desktop-terminal-operator\active-project.txt"

  if(Test-Path $j){
    try{
      $x=Get-Content $j -Raw | ConvertFrom-Json
      if($x.active_project -and (Test-Path ([string]$x.active_project))){ return [string]$x.active_project }
    }catch{}
  }

  if(Test-Path $t){
    $y=(Get-Content $t -Raw).Trim()
    if(Test-Path $y){ return $y }
  }

  return ""
}

function RunTool($name,$args=@()){
  $path=Join-Path $ToolDir $name
  if(-not(Test-Path $path)){
    W "NO_GO herramienta_no_encontrada=$path" Red
    P
    return
  }
  & powershell -NoProfile -ExecutionPolicy Bypass -File $path @args
}

function OpenFolder($path){
  if(Test-Path $path){ Start-Process explorer.exe $path }
  else{ W "NO_GO carpeta_no_encontrada=$path" Yellow; P }
}

function Status(){
  Clear-Host
  $p=ActiveProject

  W "==== ESTADO ACTUAL ENGREMIAT ====" Cyan
  W "Core: $Core" White

  if($p){
    W "Proyecto activo: $(Split-Path $p -Leaf)" Green
    W "Ruta: $p" DarkGray
  } else {
    W "Proyecto activo: NO_DETECTADO" Yellow
  }

  W ""
  W "PANTALLAS" Yellow

  $checks=@(
    @{label="Inicio / operador"; file="eng-desktop-terminal-operator.ps1"},
    @{label="Modulos proyecto"; file="eng-project-modules-screen.ps1"},
    @{label="Biblioteca modulos"; file="eng-module-library-screen.ps1"},
    @{label="Workspace modulo"; file="eng-module-workspace-screen.ps1"},
    @{label="Tarjetas modulo"; file="eng-module-cards-screen.ps1"},
    @{label="Grafo modulos"; file="eng-refresh-project-module-graph.ps1"}
  )

  foreach($c in $checks){
    $path=Join-Path $ToolDir $c.file
    if(Test-Path $path){ W (" OK   {0}" -f $c.label) Green }
    else{ W (" MISS {0}" -f $c.label) Yellow }
  }

  W ""

  if($p){
    $modsDir=Join-Path $p "MODULOS"
    $mods=if(Test-Path $modsDir){ @(Get-ChildItem $modsDir -Directory -ErrorAction SilentlyContinue).Count }else{0}
    W "Modulos proyecto activo: $mods" White
  }

  $libA="C:\ENGREMIAT_CORE\library\modules"
  $libH="C:\ENGREMIAT_CORE\library\modules_historico"
  $act=if(Test-Path $libA){ @(Get-ChildItem $libA -Directory -ErrorAction SilentlyContinue).Count }else{0}
  $his=if(Test-Path $libH){ @(Get-ChildItem $libH -Directory -ErrorAction SilentlyContinue).Count }else{0}
  W "Biblioteca modulos: $act activos / $his historicos" White

  P
}

function Main(){
  while($true){
    $p=ActiveProject

    Clear-Host
    W "==== ENGREMIAT INICIO ====" Cyan
    W "Entrada actualizada al sistema operativo local" DarkCyan
    W ""

    if($p){ W "Proyecto activo: $(Split-Path $p -Leaf)" Green }
    else{ W "Proyecto activo: NO_DETECTADO" Yellow }

    W ""
    W "INICIO / OPERADOR" Yellow
    W "1 = abrir operador principal" White
    W "2 = estado actual del sistema" White
    W "3 = abrir carpeta proyecto activo" White

    W ""
    W "PROYECTO / MODULOS" Yellow
    W "4 = modulos del proyecto activo" White
    W "5 = biblioteca de modulos" White
    W "6 = workspace de modulo" White
    W "7 = tarjetas de modulo" White

    W ""
    W "MANTENIMIENTO" Yellow
    W "8 = refrescar grafo de modulos" White
    W "9 = abrir C:\ENGREMIAT_CORE" White

    W ""
    W "q = salir | Enter = refrescar" Cyan
    W ""

    $cmd=Read-Host "ENGREMIAT_INICIO"

    if([string]::IsNullOrWhiteSpace($cmd)){ continue }
    if($cmd -eq "q"){ return }

    if($cmd -eq "1"){
      if(Test-Path (Join-Path $ToolDir "eng-desktop-terminal-operator.ps1")){
        RunTool "eng-desktop-terminal-operator.ps1"
      } elseif(Test-Path (Join-Path $ToolDir "eng-terminal-operator.ps1")){
        RunTool "eng-terminal-operator.ps1"
      } else {
        W "NO_GO operador_principal_no_encontrado" Red
        P
      }
      continue
    }

    if($cmd -eq "2"){ Status; continue }

    if($cmd -eq "3"){
      if($p){ OpenFolder $p }
      else{ W "NO_GO proyecto_activo_no_detectado" Yellow; P }
      continue
    }

    if($cmd -eq "4"){
      if($p){ RunTool "eng-project-modules-screen.ps1" @("-ProjectPath",$p) }
      else{ RunTool "eng-project-modules-screen.ps1" }
      continue
    }

    if($cmd -eq "5"){
      if($p){ RunTool "eng-module-library-screen.ps1" @("-ProjectPath",$p) }
      else{ RunTool "eng-module-library-screen.ps1" }
      continue
    }

    if($cmd -eq "6"){
      if($p){ RunTool "eng-module-workspace-screen.ps1" @("-ProjectPath",$p) }
      else{ RunTool "eng-module-workspace-screen.ps1" }
      continue
    }

    if($cmd -eq "7"){
      if($p){ RunTool "eng-module-cards-screen.ps1" @("-ProjectPath",$p) }
      else{ RunTool "eng-module-cards-screen.ps1" }
      continue
    }

    if($cmd -eq "8"){
      if($p){ RunTool "eng-refresh-project-module-graph.ps1" @("-ProjectPath",$p) }
      else{ RunTool "eng-refresh-project-module-graph.ps1" }
      continue
    }

    if($cmd -eq "9"){ OpenFolder $Core; continue }
  }
}

Main
