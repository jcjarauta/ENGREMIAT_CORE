function GenerateDocs(){
  $ctx=BuildContext
  $contextPath=SaveContext $ctx
  $stamp=Get-Date -Format "yyyyMMdd-HHmmss"
  $outputs=@(
    @{ name="memoria-tecnica"; dir="technical"; lines=(BuildTechnical $ctx) },
    @{ name="resumen-humano"; dir="executive"; lines=(BuildHumanSummary $ctx) },
    @{ name="informe-desarrollo"; dir="development"; lines=(BuildDevelopmentReport $ctx) },
    @{ name="dossier-subvenciones-base"; dir="grants"; lines=(BuildGrantDossier $ctx) },
    @{ name="dossier-partners-base"; dir="partners"; lines=(BuildPartnerDossier $ctx) },
    @{ name="dossier-clientes-base"; dir="clients"; lines=(BuildClientDossier $ctx) },
    @{ name="worker-context"; dir="worker"; lines=(BuildWorkerPrompt $ctx) }
  )
  $written=@()
  foreach($o in $outputs){
    $folder=Join-Path $DocDir $o.dir
    $latest=Join-Path $folder ($o.name + "-latest.md")
    $versioned=Join-Path $folder ($o.name + "-" + $stamp + ".md")
    $o.lines | Set-Content $latest -Encoding UTF8
    $o.lines | Set-Content $versioned -Encoding UTF8
    $written += [pscustomobject]@{ name=$o.name; latest=$latest; versioned=$versioned }
  }
  $report=Join-Path $OutReportDir ("memory-documentation-center-"+$stamp+".json")
  [pscustomobject]@{ package="ENGREMIAT_MEMORY_DOCUMENTATION_CENTER_001_E03_STABLE_EXPORT"; status="PASS"; generated=(Get-Date).ToString("s"); context=$contextPath; documents=$written; next="REVIEW_EXPORTS" } | ConvertTo-Json -Depth 60 | Set-Content $report -Encoding UTF8
  return [pscustomobject]@{ context=$contextPath; report=$report; documents=$written }
}

function FindPandoc(){ $cmd=Get-Command pandoc -ErrorAction SilentlyContinue; if($cmd -and $cmd.Source){ return $cmd.Source }; return "" }

function ExportDocuments(){
  $pandoc=FindPandoc
  $stamp=Get-Date -Format "yyyyMMdd-HHmmss"
  $exportRoot=Join-Path $DocDir "exports"
  New-Item -ItemType Directory -Force -Path $exportRoot | Out-Null
  $sources=@(
    @{ name="dossier-subvenciones-base"; path=(Join-Path $DocDir "grants\dossier-subvenciones-base-latest.md") },
    @{ name="dossier-partners-base"; path=(Join-Path $DocDir "partners\dossier-partners-base-latest.md") },
    @{ name="dossier-clientes-base"; path=(Join-Path $DocDir "clients\dossier-clientes-base-latest.md") },
    @{ name="informe-desarrollo"; path=(Join-Path $DocDir "development\informe-desarrollo-latest.md") },
    @{ name="resumen-humano"; path=(Join-Path $DocDir "executive\resumen-humano-latest.md") },
    @{ name="memoria-tecnica"; path=(Join-Path $DocDir "technical\memoria-tecnica-latest.md") }
  )
  $results=@()
  foreach($s in $sources){
    if(-not(Test-Path $s.path)){ $results += [pscustomobject]@{ source=$s.path; status="MISS_SOURCE"; html=""; docx=""; message="Genera primero [1]." }; continue }
    $html=Join-Path $exportRoot ($s.name + "-latest.html")
    $docx=Join-Path $exportRoot ($s.name + "-latest.docx")
    if($pandoc){
      try{
        & $pandoc $s.path -o $html --standalone
        if($LASTEXITCODE -ne 0){ throw "pandoc_html_exit=$LASTEXITCODE" }
        & $pandoc $s.path -o $docx
        if($LASTEXITCODE -ne 0){ throw "pandoc_docx_exit=$LASTEXITCODE" }
        Copy-Item $html (Join-Path $exportRoot ($s.name + "-" + $stamp + ".html")) -Force
        Copy-Item $docx (Join-Path $exportRoot ($s.name + "-" + $stamp + ".docx")) -Force
        $results += [pscustomobject]@{ source=$s.path; status="EXPORTED"; html=$html; docx=$docx; message="OK" }
      }catch{
        $results += [pscustomobject]@{ source=$s.path; status="EXPORT_ERROR"; html=$html; docx=$docx; message=$_.Exception.Message }
      }
    }else{
      $fallback=Join-Path $exportRoot ($s.name + "-latest.md")
      Copy-Item $s.path $fallback -Force
      $results += [pscustomobject]@{ source=$s.path; status="PANDOC_NOT_FOUND_MD_COPIED"; html=""; docx=""; message="Pandoc no detectado. Copiado Markdown a exports." }
    }
  }
  $installNote=Join-Path $exportRoot "README-pandoc-install.md"
  @("# Exportación documental Engremiat","","Estado pandoc: " + $(if($pandoc){"DETECTADO: $pandoc"}else{"NO_DETECTADO"}),"","Comprobación:","```powershell","pandoc --version","```") | Set-Content $installNote -Encoding UTF8
  $report=Join-Path $OutReportDir ("document-export-pandoc-"+$stamp+".json")
  [pscustomobject]@{ package="ENGREMIAT_DOCUMENT_EXPORT_001_E01_PANDOC_EXPORT"; status="PASS"; generated=(Get-Date).ToString("s"); pandoc_detected=[bool]$pandoc; pandoc_path=$pandoc; exports_dir=$exportRoot; install_note=$installNote; results=$results; next="REVIEW_EXPORTS" } | ConvertTo-Json -Depth 80 | Set-Content $report -Encoding UTF8
  return [pscustomobject]@{ pandoc=$pandoc; report=$report; exports=$exportRoot; install_note=$installNote; results=$results }
}

function ShowExportResult($r){
  Clear-Host
  W "==== EXPORTACIÓN DOCUMENTAL ====" Cyan
  W ""
  if($r.pandoc){ W ("[OK] pandoc: {0}" -f $r.pandoc) Green } else { W "[WARN] pandoc no detectado; se copiaron Markdown a exports." Yellow }
  W ""
  foreach($x in $r.results){
    $color=if($x.status -eq "EXPORTED"){"Green"}elseif($x.status -like "PANDOC_NOT_FOUND*"){"Yellow"}else{"Red"}
    W ("[{0}] {1}" -f $x.status,$x.source) $color
    if($x.html){ W ("  HTML: {0}" -f $x.html) DarkCyan }
    if($x.docx){ W ("  DOCX: {0}" -f $x.docx) DarkCyan }
    if($x.message -and $x.message -ne "OK"){ W ("  nota: {0}" -f $x.message) Yellow }
  }
  W ""
  W ("exports: {0}" -f $r.exports) Green
  W ("report:  {0}" -f $r.report) Green
  W ("nota:    {0}" -f $r.install_note) DarkCyan
  W ""
  W "[Enter] volver" Cyan
  W ""
  [void](Read-Host "EXPORTAR")
}

function ShowToolingStatus(){
  Clear-Host
  W "==== HERRAMIENTAS DOCUMENTALES ====" Cyan
  W ""
  $pandoc=FindPandoc
  if($pandoc){
    W "[OK] pandoc detectado" Green
    W ("ruta: {0}" -f $pandoc) DarkCyan
    try{ W ("version: {0}" -f (& $pandoc --version | Select-Object -First 1)) White }catch{}
  }else{
    W "[MISS] pandoc no detectado" Yellow
    W "Exportación DOCX/HTML automática no disponible todavía." White
  }
  W ""
  W ("Carpeta exports: {0}" -f (Join-Path $DocDir "exports")) Green
  W ""
  W "[Enter] volver" Cyan
  W ""
  [void](Read-Host "HERRAMIENTAS")
}

