  W ""
  foreach($x in $r.results){
    W ("[{0}] {1}" -f $x.status,$x.source) $(if($x.status -eq "EXPORTED"){"Green"}elseif($x.status -like "PANDOC_NOT_FOUND*"){"Yellow"}else{"Red"})
    if($x.html){ W ("  HTML: {0}" -f $x.html) DarkCyan }
    if($x.docx){ W ("  DOCX: {0}" -f $x.docx) DarkCyan }
    if($x.message -and $x.message -ne "OK"){ W ("  nota: {0}" -f $x.message) Yellow }
  }
  W ""
  W ("exports: {0}" -f $r.exports) Green
  W ("report:  {0}" -f $r.report) Green
  W ""
  W "[Enter] volver" Cyan
  W ""
  [void](Read-Host "EXPORTAR")
}

function Show-Main {
  Clear-Host
  W "==== MEMORIA Y DOCUMENTACIÓN ====" Cyan
  W ""
  W "Centro local-first para memoria viva, informes, dossiers, contexto worker y exportación documental." DarkCyan
  W ""
  W "[1] generar paquete documental completo" White
  W "[2] abrir memoria técnica" White
  W "[3] abrir resumen humano" White
  W "[4] abrir informe de desarrollo" White
  W "[5] abrir dossier subvenciones" White
  W "[6] abrir dossier partners" White
  W "[7] abrir dossier clientes" White
  W "[8] abrir contexto worker" White
  W "[9] abrir carpeta documents" White
  W "[10] abrir contexto JSON" White
  W "[11] exportar documentos DOCX/HTML con Pandoc" White
  W "[12] abrir carpeta exports" White
  W "[13] verificar herramientas documentales" White
  W "[b] atrás | [Enter] refrescar" Cyan
  W ""
}

while($true){
  Show-Main
  $cmd = Read-Host "DOCUMENTACION"
  if([string]::IsNullOrWhiteSpace($cmd)){ continue }
  if($cmd -eq "b"){ return }
  if($cmd -eq "1"){
    $r = Build-Docs
    Clear-Host
    W "==== DOCUMENTOS GENERADOS ====" Cyan
    W ""
    foreach($d in $r.documents){ W ("[OK] {0}: {1}" -f $d.name,$d.latest) Green }
    W ""
    W ("contexto: {0}" -f $r.context) Green
    W ("report:   {0}" -f $r.report) Green
    W ""
    W "[Enter] volver" Cyan
    W ""
    [void](Read-Host "DOCUMENTOS")
    continue
  }
  if($cmd -eq "2"){ Open-Latest "technical\memoria-tecnica-latest.md"; continue }
  if($cmd -eq "3"){ Open-Latest "executive\resumen-humano-latest.md"; continue }
  if($cmd -eq "4"){ Open-Latest "development\informe-desarrollo-latest.md"; continue }
  if($cmd -eq "5"){ Open-Latest "grants\dossier-subvenciones-base-latest.md"; continue }
  if($cmd -eq "6"){ Open-Latest "partners\dossier-partners-base-latest.md"; continue }
  if($cmd -eq "7"){ Open-Latest "clients\dossier-clientes-base-latest.md"; continue }
  if($cmd -eq "8"){ Open-Latest "worker\worker-context-latest.md"; continue }
  if($cmd -eq "9"){ Open-Folder $DocDir; continue }
  if($cmd -eq "10"){ Open-Latest "document-context-latest.json"; continue }
  if($cmd -eq "11"){ $r=Export-Docs; Show-Export $r; continue }
  if($cmd -eq "12"){ Open-Folder (Join-Path $DocDir "exports"); continue }
  if($cmd -eq "13"){ Show-Tooling; continue }
  W "WARN comando_no_reconocido" Yellow
  Pause-Eng
}

