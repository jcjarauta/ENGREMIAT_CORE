function Find-Pandoc {
  $cmd = Get-Command pandoc -ErrorAction SilentlyContinue
  if($cmd -and $cmd.Source){ return $cmd.Source }
  return ""
}

function Export-Docs {
  $pandoc = Find-Pandoc
  $exportDir = Join-Path $DocDir "exports"
  New-Item -ItemType Directory -Force -Path $exportDir | Out-Null
  $sources = @(
    "grants\dossier-subvenciones-base-latest.md",
    "partners\dossier-partners-base-latest.md",
    "clients\dossier-clientes-base-latest.md",
    "development\informe-desarrollo-latest.md",
    "executive\resumen-humano-latest.md",
    "technical\memoria-tecnica-latest.md"
  )

  $results = @()
  foreach($rel in $sources){
    $src = Join-Path $DocDir $rel
    $base = [IO.Path]::GetFileNameWithoutExtension($src)
    if(-not(Test-Path $src)){
      $results += [pscustomobject]@{ status="MISS_SOURCE"; source=$src; html=""; docx=""; message="Genera primero [1]." }
      continue
    }

    if($pandoc){
      $html = Join-Path $exportDir ($base + ".html")
      $docx = Join-Path $exportDir ($base + ".docx")
      try{
        & $pandoc $src -o $html --standalone
        $code1 = $LASTEXITCODE
        & $pandoc $src -o $docx
        $code2 = $LASTEXITCODE
        if($code1 -eq 0 -and $code2 -eq 0){
          $results += [pscustomobject]@{ status="EXPORTED"; source=$src; html=$html; docx=$docx; message="OK" }
        } else {
          $results += [pscustomobject]@{ status="EXPORT_ERROR"; source=$src; html=$html; docx=$docx; message="pandoc exit html=$code1 docx=$code2" }
        }
      } catch {
        $results += [pscustomobject]@{ status="EXPORT_ERROR"; source=$src; html=$html; docx=$docx; message=$_.Exception.Message }
      }
    } else {
      $fallback = Join-Path $exportDir ([IO.Path]::GetFileName($src))
      Copy-Item $src $fallback -Force
      $results += [pscustomobject]@{ status="PANDOC_NOT_FOUND_MD_COPIED"; source=$src; html=""; docx=""; message="Pandoc no detectado. Markdown copiado a exports." }
    }
  }

  $note = Join-Path $exportDir "README-pandoc-install.md"
  @(
    "# Exportación documental Engremiat",
    "",
    "Estado pandoc: " + $(if($pandoc){"DETECTADO: $pandoc"}else{"NO_DETECTADO"}),
    "",
    "Comprobación:",
    "pandoc --version"
  ) | Set-Content $note -Encoding UTF8

  $report = Join-Path $ReportDir ("document-export-pandoc-safe-" + (Get-Date -Format "yyyyMMdd-HHmmss") + ".json")
  [pscustomobject]@{
    package = "ENGREMIAT_DOCUMENT_EXPORT_SAFE"
    status = "PASS"
    pandoc_detected = [bool]$pandoc
    pandoc_path = $pandoc
    exports_dir = $exportDir
    install_note = $note
    results = $results
  } | ConvertTo-Json -Depth 50 | Set-Content $report -Encoding UTF8

  return [pscustomobject]@{ pandoc=$pandoc; results=$results; exports=$exportDir; report=$report; note=$note }
}

