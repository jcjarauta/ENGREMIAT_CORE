function W($m,$c="White"){ Write-Host $m -ForegroundColor $c }
function Pause-Eng(){ [void](Read-Host "Enter") }

function Get-ActiveProject {
  $j = Join-Path $Core "data\desktop-terminal-operator\active-project.json"
  $t = Join-Path $Core "data\desktop-terminal-operator\active-project.txt"
  if(Test-Path $j){
    try{
      $x = Get-Content $j -Raw | ConvertFrom-Json
      if($x.active_project -and (Test-Path ([string]$x.active_project))){ return [string]$x.active_project }
    } catch {}
  }
  if(Test-Path $t){
    $v = (Get-Content $t -Raw).Trim()
    if(Test-Path $v){ return $v }
  }
  return ""
}

function Normalize-Status($s){
  $v = ([string]$s).Trim().ToUpperInvariant()
  if($v -eq "ACTIVE" -or $v -eq "ACTIVO"){ return "ACTIVO" }
  if($v -eq "INACTIVE" -or $v -eq "INACTIVO" -or $v -eq "DISABLED" -or $v -eq "DESACTIVADO"){ return "INACTIVO" }
  if($v -eq "HISTORIC" -or $v -eq "HISTORICAL" -or $v -eq "HISTORICO" -or $v -eq "HISTÓRICO"){ return "HISTORICO" }
  if([string]::IsNullOrWhiteSpace($v)){ return "ACTIVO" }
  return $v
}

function Get-ModuleStatus($dir){
  $mj = Join-Path $dir "module.json"
  if(Test-Path $mj){
    try{
      $x = Get-Content $mj -Raw | ConvertFrom-Json
      if($x.status){ return Normalize-Status $x.status }
    } catch {}
  }
  return "ACTIVO"
}

function Count-Dirs($path){
  if(Test-Path $path){ return @((Get-ChildItem $path -Directory -ErrorAction SilentlyContinue)).Count }
  return 0
}

function Get-LibraryCounts {
  $lib = Join-Path $Core "library\modules"
  $hist = Join-Path $Core "library\modules_historico"
  $active = 0
  $inactive = 0
  if(Test-Path $lib){
    foreach($d in Get-ChildItem $lib -Directory -ErrorAction SilentlyContinue){
      if((Get-ModuleStatus $d.FullName) -eq "INACTIVO"){ $inactive++ } else { $active++ }
    }
  }
  return [pscustomobject]@{
    active = $active
    inactive = $inactive
    historic = Count-Dirs $hist
  }
}

function Get-Context {
  $p = Get-ActiveProject
  $projectName = "NO_DETECTADO"
  $modules = 0
  if($p){
    $projectName = Split-Path $p -Leaf
    $modules = Count-Dirs (Join-Path $p "MODULOS")
  }
  $lib = Get-LibraryCounts
  return [pscustomobject]@{
    generated = (Get-Date).ToString("s")
    core = $Core
    project_path = $p
    project_name = $projectName
    project_modules = $modules
    library_active = $lib.active
    library_inactive = $lib.inactive
    library_historic = $lib.historic
    next = "E24A_CREATE_MODULE_TASKS_MANAGEMENT_SCREEN"
  }
}

function Save-Doc($folder,$name,$lines){
  $targetDir = Join-Path $DocDir $folder
  New-Item -ItemType Directory -Force -Path $targetDir | Out-Null
  $latest = Join-Path $targetDir ($name + "-latest.md")
  $versioned = Join-Path $targetDir ($name + "-" + (Get-Date -Format "yyyyMMdd-HHmmss") + ".md")
  $lines | Set-Content $latest -Encoding UTF8
  $lines | Set-Content $versioned -Encoding UTF8
  return [pscustomobject]@{ name=$name; latest=$latest; versioned=$versioned }
}

