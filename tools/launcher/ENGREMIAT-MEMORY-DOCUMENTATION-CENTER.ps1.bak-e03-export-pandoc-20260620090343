function GenerateDocs(){
  $ctx=BuildContext
  $contextPath=SaveContext $ctx
  $stamp=Get-Date -Format "yyyyMMdd-HHmmss"

  $outputs=@(
    @{ name="memoria-tecnica"; dir="technical"; lines=(BuildTechnical $ctx) },
    @{ name="resumen-humano"; dir="executive"; lines=(BuildHumanSummary $ctx) },
    @{ name="informe-desarrollo"; dir="development"; lines=(BuildDevelopmentReport $ctx) },
    @{ name="dossier-subvenciones-base"; dir="grants"; lines=(BuildGrantDossier $ctx) },
    @{ name="dossier-partners-base"; dir="partners"; lines=(BuildPartnerDossier $ctx) },
    @{ name="dossier-clientes-base"; dir="clients"; lines=(BuildClientDossier $ctx) },
    @{ name="worker-context"; dir="worker"; lines=(BuildWorkerPrompt $ctx) }
  )

  $written=@()
  foreach($o in $outputs){
    $folder=Join-Path $DocDir $o.dir
    New-Item -ItemType Directory -Force -Path $folder | Out-Null
    $latest=Join-Path $folder ($o.name + "-latest.md")
    $versioned=Join-Path $folder ($o.name + "-" + $stamp + ".md")
    $o.lines | Set-Content $latest -Encoding UTF8
    $o.lines | Set-Content $versioned -Encoding UTF8
    $written += [pscustomobject]@{ name=$o.name; latest=$latest; versioned=$versioned }
  }

  $report=Join-Path $OutReportDir ("memory-documentation-center-"+$stamp+".json")
  [pscustomobject]@{
    package="ENGREMIAT_MEMORY_DOCUMENTATION_CENTER_001_E01"
    status="PASS"
    generated=(Get-Date).ToString("s")
    context=$contextPath
    documents=$written
    worker_enabled=$false
    export_docx_pdf=$false
    next="E02_DOCUMENT_CENTER_SCREEN_REVIEW_AND_EXPORT_PLAN"
  } | ConvertTo-Json -Depth 60 | Set-Content $report -Encoding UTF8

  return [pscustomobject]@{ context=$contextPath; report=$report; documents=$written }
}

function OpenFolder($path){
  if(Test-Path $path){ Start-Process explorer.exe $path }
}

function ShowMain(){
  Clear-Host
  W "==== MEMORIA Y DOCUMENTACIÓN ====" Cyan
  W ""
  W "Centro local-first para memoria viva, informes, dossiers y contexto worker." DarkCyan
  W ""
  W "[1] generar paquete documental completo" White
  W "[2] abrir memoria técnica" White
  W "[3] abrir resumen humano" White
  W "[4] abrir informe de desarrollo" White
  W "[5] abrir dossier subvenciones" White
  W "[6] abrir dossier partners" White
  W "[7] abrir dossier clientes" White
  W "[8] abrir contexto worker" White
  W "[9] abrir carpeta documents" White
  W "[10] abrir contexto JSON" White
  W "[b] atrás | [Enter] refrescar" Cyan
  W ""
}

function OpenLatest($rel){
  $path=Join-Path $DocDir $rel
  if(Test-Path $path){ Start-Process notepad.exe $path }
  else{ W "NO_GO documento_no_existe. Genera primero [1]." Yellow; P }
}

while($true){
  ShowMain
  $cmd=Read-Host "DOCUMENTACION"
  if([string]::IsNullOrWhiteSpace($cmd)){ continue }
  if($cmd -eq "b"){ return }

  if($cmd -eq "1"){
    $r=GenerateDocs
    Clear-Host
    W "==== DOCUMENTOS GENERADOS ====" Cyan
    W ""
    foreach($d in $r.documents){ W ("[OK] {0}: {1}" -f $d.name,$d.latest) Green }
    W ""
    W ("contexto: {0}" -f $r.context) Green
    W ("report:   {0}" -f $r.report) Green
    W ""
    W "[Enter] volver" Cyan
    W ""
    [void](Read-Host "DOCUMENTOS")
    continue
  }

  if($cmd -eq "2"){ OpenLatest "technical\memoria-tecnica-latest.md"; continue }
  if($cmd -eq "3"){ OpenLatest "executive\resumen-humano-latest.md"; continue }
  if($cmd -eq "4"){ OpenLatest "development\informe-desarrollo-latest.md"; continue }
  if($cmd -eq "5"){ OpenLatest "grants\dossier-subvenciones-base-latest.md"; continue }
  if($cmd -eq "6"){ OpenLatest "partners\dossier-partners-base-latest.md"; continue }
  if($cmd -eq "7"){ OpenLatest "clients\dossier-clientes-base-latest.md"; continue }
  if($cmd -eq "8"){ OpenLatest "worker\worker-context-latest.md"; continue }
  if($cmd -eq "9"){ OpenFolder $DocDir; continue }
  if($cmd -eq "10"){ OpenLatest "document-context-latest.json"; continue }

  W "WARN comando_no_reconocido" Yellow
  P
}

