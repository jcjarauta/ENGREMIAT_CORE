function W($m,$c="White"){ Write-Host $m -ForegroundColor $c }
function P(){ [void](Read-Host "Enter") }

function ActiveProject(){
  $j=Join-Path $Core "data\desktop-terminal-operator\active-project.json"
  $t=Join-Path $Core "data\desktop-terminal-operator\active-project.txt"
  if(Test-Path $j){
    try{
      $x=Get-Content $j -Raw | ConvertFrom-Json
      if($x.active_project -and (Test-Path ([string]$x.active_project))){ return [string]$x.active_project }
    }catch{}
  }
  if(Test-Path $t){
    $y=(Get-Content $t -Raw).Trim()
    if(Test-Path $y){ return $y }
  }
  return ""
}

function NormalizeStatus($status){
  $s=([string]$status).Trim().ToUpperInvariant()
  if($s -eq "ACTIVE" -or $s -eq "ACTIVO"){ return "ACTIVO" }
  if($s -eq "INACTIVE" -or $s -eq "INACTIVO" -or $s -eq "DISABLED" -or $s -eq "DESACTIVADO"){ return "INACTIVO" }
  if($s -eq "HISTORIC" -or $s -eq "HISTORICAL" -or $s -eq "HISTORICO" -or $s -eq "HISTÓRICO"){ return "HISTORICO" }
  if([string]::IsNullOrWhiteSpace($s)){ return "ACTIVO" }
  return $s
}

function ModuleStatus($dir){
  $mj=Join-Path $dir "module.json"
  if(Test-Path $mj){
    try{
      $j=Get-Content $mj -Raw | ConvertFrom-Json
      if($j.status){ return NormalizeStatus $j.status }
    }catch{}
  }
  return "ACTIVO"
}

function CountDirs($path){
  if(Test-Path $path){ return @((Get-ChildItem $path -Directory -ErrorAction SilentlyContinue)).Count }
  return 0
}

function CountLibrary(){
  $lib=Join-Path $Core "library\modules"
  $hist=Join-Path $Core "library\modules_historico"
  $active=0
  $inactive=0
  if(Test-Path $lib){
    foreach($d in (Get-ChildItem $lib -Directory -ErrorAction SilentlyContinue)){
      $st=ModuleStatus $d.FullName
      if($st -eq "INACTIVO"){ $inactive++ } else { $active++ }
    }
  }
  return [pscustomobject]@{ active=$active; inactive=$inactive; historic=(CountDirs $hist) }
}

function LatestReports(){
  $items=@()
  foreach($root in @((Join-Path $Core "reports\launcher"),(Join-Path $Core "reports\navigation"))){
    if(Test-Path $root){
      foreach($f in (Get-ChildItem $root -Filter "*.json" -File -ErrorAction SilentlyContinue | Sort-Object LastWriteTime -Descending | Select-Object -First 15)){
        try{
          $j=Get-Content $f.FullName -Raw | ConvertFrom-Json
          $items += [pscustomobject]@{ name=$f.Name; status=if($j.status){$j.status}else{"UNKNOWN"}; package=if($j.package){$j.package}else{""}; next=if($j.next){$j.next}else{""}; path=$f.FullName }
        }catch{
          $items += [pscustomobject]@{ name=$f.Name; status="UNREADABLE"; package=""; next=""; path=$f.FullName }
        }
      }
    }
  }
  return @($items | Sort-Object name -Descending | Select-Object -First 15)
}

function BuildContext(){
  $p=ActiveProject
  $lib=CountLibrary
  $modules=0
  if($p){ $modules=CountDirs (Join-Path $p "MODULOS") }
  $reports=LatestReports
  $memoryMd=Join-Path $MemoryDir "project-memory-latest.md"
  $diaryMd=Join-Path $MemoryDir "development-diary-latest.md"
  $memoryText=if(Test-Path $memoryMd){ Get-Content $memoryMd -Raw }else{""}
  $diaryText=if(Test-Path $diaryMd){ Get-Content $diaryMd -Raw }else{""}
  return [pscustomobject]@{
    generated=(Get-Date).ToString("s")
    core=$Core
    project_path=$p
    project_name=if($p){ Split-Path $p -Leaf }else{"NO_DETECTADO"}
    project_modules=$modules
    library_active=$lib.active
    library_inactive=$lib.inactive
    library_historic=$lib.historic
    reports=$reports
    memory_md=$memoryMd
    diary_md=$diaryMd
    memory_excerpt=($memoryText -split "`r?`n" | Select-Object -First 40) -join "`n"
    diary_excerpt=($diaryText -split "`r?`n" | Select-Object -First 30) -join "`n"
    next="E24A_CREATE_MODULE_TASKS_MANAGEMENT_SCREEN"
  }
}

function SaveContext($ctx){
  $path=Join-Path $DocDir "document-context-latest.json"
  $ctx | ConvertTo-Json -Depth 60 | Set-Content $path -Encoding UTF8
  return $path
}

function ReportLines($ctx){
  $lines=@()
  $lines += "Generado: $($ctx.generated)"
  $lines += "Core: $($ctx.core)"
  $lines += "Proyecto activo: $($ctx.project_name)"
  $lines += "Ruta proyecto: $($ctx.project_path)"
  $lines += "Módulos proyecto: $($ctx.project_modules)"
  $lines += "Biblioteca: $($ctx.library_active) activos / $($ctx.library_inactive) inactivos / $($ctx.library_historic) históricos"
  return $lines
}

function BuildTechnical($ctx){
  $lines=@("# ENGREMIAT - Memoria técnica","","## Estado base")
  $lines += ReportLines $ctx
  $lines += ""
  $lines += "## Reports recientes"
  foreach($r in $ctx.reports){ $lines += "- [$($r.status)] $($r.name) · package=$($r.package) · next=$($r.next)" }
  $lines += ""
  $lines += "## Siguiente técnico recomendado"
  $lines += "- $($ctx.next)"
  return $lines
}

