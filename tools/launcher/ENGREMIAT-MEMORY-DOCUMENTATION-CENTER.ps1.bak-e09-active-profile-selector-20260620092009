function Ask-GrantField {
  param([string]$Label,[object]$Current,[int]$Index,[int]$Total)
  $currentText = ""
  if($Current -is [System.Array]){ $currentText = ($Current -join "; ") } else { $currentText = [string]$Current }
  Clear-Host
  W "==== ASISTENTE FICHA CONVOCATORIA ====" Cyan
  W ""
  W ("Campo {0}/{1}: {2}" -f $Index,$Total,$Label) Yellow
  W ""
  W ("Actual: {0}" -f $currentText) DarkCyan
  W ""
  W "Escribe nuevo valor, Enter = mantener, cancelar = salir sin guardar." White
  W ""
  $v = Read-Host "VALOR"
  if($v -eq "cancelar"){ throw "WIZARD_CANCELLED_BY_USER" }
  if([string]::IsNullOrWhiteSpace($v)){ return $Current }
  return $v
}

function Ask-GrantListField {
  param([string]$Label,[object]$Current,[int]$Index,[int]$Total)
  $currentText = ""
  if($Current -is [System.Array]){ $currentText = ($Current -join "; ") } else { $currentText = [string]$Current }
  Clear-Host
  W "==== ASISTENTE FICHA CONVOCATORIA ====" Cyan
  W ""
  W ("Campo {0}/{1}: {2}" -f $Index,$Total,$Label) Yellow
  W ""
  W ("Actual: {0}" -f $currentText) DarkCyan
  W ""
  W "Escribe elementos separados con ;  | Enter = mantener | cancelar = salir sin guardar." White
  W ""
  $v = Read-Host "VALOR"
  if($v -eq "cancelar"){ throw "WIZARD_CANCELLED_BY_USER" }
  if([string]::IsNullOrWhiteSpace($v)){ return $Current }
  $items = @()
  foreach($x in ($v -split ";")){ $s=$x.Trim(); if(-not([string]::IsNullOrWhiteSpace($s))){ $items += $s } }
  return @($items)
}

