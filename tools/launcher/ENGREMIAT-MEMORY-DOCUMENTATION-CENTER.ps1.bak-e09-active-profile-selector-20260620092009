function Join-ProfileList($v) {
  if($null -eq $v){ return "- PENDIENTE_DEFINIR" }
  if($v -is [System.Array]){
    $out = @()
    foreach($x in $v){ $out += ("- " + [string]$x) }
    return ($out -join "`r`n")
  }
  return ("- " + [string]$v)
}

function Test-GrantProfileValue {
  param([object]$Value)

  if($null -eq $Value){ return $false }

  if($Value -is [System.Array]){
    if($Value.Count -eq 0){ return $false }
    foreach($v in $Value){
      $s = ([string]$v).Trim()
      if([string]::IsNullOrWhiteSpace($s)){ return $false }
      if($s -eq "PENDIENTE_DEFINIR"){ return $false }
    }
    return $true
  }

  $txt = ([string]$Value).Trim()
  if([string]::IsNullOrWhiteSpace($txt)){ return $false }
  if($txt -eq "PENDIENTE_DEFINIR"){ return $false }
  return $true
}

function Get-GrantProfileMissingFields {
  param([object]$Profile)

  $required = @(
    "nombre_convocatoria",
    "entidad_convocante",
    "territorio",
    "fecha_limite",
    "objetivo_convocatoria",
    "lineas_prioritarias",
    "importe_solicitado",
    "cofinanciacion",
    "beneficiarios",
    "indicadores_requeridos",
    "documentacion_requerida",
    "criterios_valoracion",
    "tono"
  )

  $missing = @()

  foreach($field in $required){
    $value = $null
    try { $value = $Profile.$field } catch { $value = $null }
    if(-not(Test-GrantProfileValue $value)){
      $missing += $field
    }
  }

  return @($missing)
}

function Confirm-GrantProfileBeforeGenerate {
  param([object]$Profile)

  $missing = Get-GrantProfileMissingFields $Profile

  if($missing.Count -eq 0){
    return $true
  }

  Clear-Host
  W "==== WARN FICHA DE CONVOCATORIA INCOMPLETA ====" Yellow
  W ""
  W "El dossier adaptado se puede generar, pero la ficha contiene campos pendientes." White
  W ""
  W "Campos pendientes:" Yellow
  foreach($m in $missing){
    W ("  [MISS] {0}" -f $m) Yellow
  }
  W ""
  W "Recomendado:" Cyan
  W "  [14] editar ficha de convocatoria antes de generar el dossier adaptado." White
  W ""
  W "Opciones:" Cyan
  W "  [s] generar igualmente" White
  W "  [n] cancelar y volver" White
  W ""
  $ans = Read-Host "GENERAR_CON_FICHA_INCOMPLETA"
  if($ans -eq "s" -or $ans -eq "S"){ return $true }

  W ""
  W "CANCELADO dossier_adaptado_no_generado" Yellow
  W ""
  W "[Enter] volver" Cyan
  W ""
  [void](Read-Host "DOSSIER_ADAPTADO")
  return $false
}
