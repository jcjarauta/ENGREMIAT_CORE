while($true){
  Show-Main
  $cmd = Read-Host "DOCUMENTACION"
  if([string]::IsNullOrWhiteSpace($cmd)){ continue }
  if($cmd -eq "b"){ return }
  if($cmd -eq "1"){
    $r = Build-Docs
    Clear-Host
    W "==== DOCUMENTOS GENERADOS ====" Cyan
    W ""
    foreach($d in $r.documents){ W ("[OK] {0}: {1}" -f $d.name,$d.latest) Green }
    W ""
    W ("contexto: {0}" -f $r.context) Green
    W ("report:   {0}" -f $r.report) Green
    W ""
    W "[Enter] volver" Cyan
    W ""
    [void](Read-Host "DOCUMENTOS")
    continue
  }
  if($cmd -eq "2"){ Open-Latest "technical\memoria-tecnica-latest.md"; continue }
  if($cmd -eq "3"){ Open-Latest "executive\resumen-humano-latest.md"; continue }
  if($cmd -eq "4"){ Open-Latest "development\informe-desarrollo-latest.md"; continue }
  if($cmd -eq "5"){ Open-Latest "grants\dossier-subvenciones-base-latest.md"; continue }
  if($cmd -eq "6"){ Open-Latest "partners\dossier-partners-base-latest.md"; continue }
  if($cmd -eq "7"){ Open-Latest "clients\dossier-clientes-base-latest.md"; continue }
  if($cmd -eq "8"){ Open-Latest "worker\worker-context-latest.md"; continue }
  if($cmd -eq "9"){ Open-Folder $DocDir; continue }
  if($cmd -eq "10"){ Open-Latest "document-context-latest.json"; continue }
  if($cmd -eq "11"){ $r=Export-Docs; Show-Export $r; continue }
  if($cmd -eq "12"){ Open-Folder (Join-Path $DocDir "exports"); continue }
  if($cmd -eq "13"){ Show-Tooling; continue }
  W "WARN comando_no_reconocido" Yellow
  Pause-Eng
}
