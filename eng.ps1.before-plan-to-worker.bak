# ENGREMIAT_PROMPT_FACTORY_COMMAND_HUB_V1 $ErrorActionPreference="Stop" [Console]::OutputEncoding=[System.Text.Encoding]::UTF8 $cmd = if($args.Count -gt 0){ [string]$args[0] } else { "" } if($cmd -in @("prompt-status","prompt-next","prompt-repair","prompt-open","prompt-inbox")){ & powershell -NoProfile -ExecutionPolicy Bypass -File "tools/prompt-factory/Invoke-PromptFactoryCommand.ps1" -Command $cmd; exit $LASTEXITCODE } if($cmd -in @("memory","memory-status","memory-sync","memory-dashboard","memory-graph")){ & powershell -NoProfile -ExecutionPolicy Bypass -File "tools/memory/Invoke-VisualMemoryCommand.ps1" -Command $cmd; exit $LASTEXITCODE } $original = Get-ChildItem -LiteralPath "tools/prompt-factory" -File -Filter "eng.before-prompt-factory.*.ps1" | Sort-Object LastWriteTime -Descending | Select-Object -First 1 if($null -ne $original){ & powershell -NoProfile -ExecutionPolicy Bypass -File $original.FullName @args; exit $LASTEXITCODE } Write-Host "OK eng_prompt_factory_command_hub=True available=prompt-status,prompt-next,prompt-repair,prompt-open,prompt-inbox,memory-status,memory-sync,memory-dashboard,memory-graph"
